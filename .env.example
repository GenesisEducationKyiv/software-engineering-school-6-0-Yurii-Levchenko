# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/notifier?sslmode=disable

# App
APP_PORT=8080
BASE_URL=http://localhost:8080

# SMTP (Mailtrap)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@github-notifier.local

# GitHub (optional, increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Scanner
SCAN_INTERVAL_SECONDS=300

# Redis (optional, app works without it but caching reduces GitHub API calls)
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=600
